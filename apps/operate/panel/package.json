{
  "name": "cs2-server-ops-operate-panel",
  "version": "1.0.0",
  "description": "Operate module for cs2-server-ops: authenticated web control plane for Counter-Strike 2 servers.",
  "main": "app.ts",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "npm run build:client && tsx watch app.ts",
    "dev:client": "esbuild public/ts/console.ts --bundle --outfile=public/js/console.js --target=es2020 --watch",
    "copy-fonts": "node scripts/copy-fonts.js",
    "prebuild": "npm run copy-fonts",
    "build": "tsc && npm run build:client",
    "build:client": "esbuild public/ts/console.ts --bundle --minify --outfile=public/js/console.js --target=es2020",
    "start:prod": "npm run build && npm start",
    "format:shell": "./scripts/format.sh",
    "validate": "./scripts/validate.sh",
    "lint": "eslint .",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "test": "npm run build:client && tsc && node --experimental-test-module-mocks --test --test-force-exit --test-timeout 120000 dist/test/*.test.js",
    "test:e2e:install": "playwright install chromium",
    "test:e2e": "npm run build && playwright test",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run build:client && npm test && npm run test:e2e && npm run validate -- --require-docker"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "connect-redis": "^9.0.0",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "pino": "^10.3.1",
    "rate-limit-redis": "^4.3.1",
    "rcon-srcds": "^2.1.0",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/syne": "^5.2.7",
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "overrides": {
    "minimatch@^3.0.2": "3.1.4",
    "minimatch@^5.1.2": "5.1.8",
    "qs": "6.15.0"
  }
}
